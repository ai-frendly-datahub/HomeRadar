# HomeRadar 환경 변수 설정 예시
# 이 파일을 .env로 복사하고 실제 값을 입력하세요.
# cp .env.example .env

# ====================================
# 데이터베이스 설정 (선택)
# ====================================
# DuckDB 파일 경로 (기본값: data/homeradar.duckdb)
# HOMERADAR_DB_PATH=data/homeradar.duckdb

# ====================================
# 리포트 설정 (선택)
# ====================================
# 리포트 출력 디렉토리 (기본값: docs/reports)
# REPORT_DIR=docs/reports

# ====================================
# 로깅 설정 (선택)
# ====================================
# 로그 레벨: DEBUG, INFO, WARNING, ERROR, CRITICAL
# LOG_LEVEL=INFO
# LOG_FILE=logs/homeradar.log

# ====================================
# 알림 설정 (선택)
# ====================================
# Slack 웹훅 URL (에러 알림용)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# 이메일 알림 설정 (SMTP)
# EMAIL_ENABLED=false
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SENDER=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
# EMAIL_RECEIVER=recipient@example.com

# ====================================
# HomeRadar 특화 설정
# ====================================
# 공식 primary 데이터 소스(거래/전월세/청약/공매)는 모두 data.go.kr 발급 키가 필요하다.
# 키가 없으면 home_quality.json의 official_primary_status가 blocked_missing_env로
# 보고되며, 해당 소스는 실패 대신 skip 처리된다.

# 국토교통부(MOLIT) 실거래/전월세 API 서비스 키 (molit_apt_transaction, molit_apt_rent 공용)
# 발급: https://www.data.go.kr/data/15126469/openapi.do
MOLIT_SERVICE_KEY=your-molit-service-key-here

# 한국부동산원(REB) 청약 API 서비스 키 (reb_subscription)
# 발급: https://www.data.go.kr/data/15098547/openapi.do
SUBSCRIPTION_API_KEY=your-subscription-api-key-here

# 한국자산관리공사(KAMCO) 온비드 공매 API 서비스 키 (onbid_auction)
# 발급: https://www.data.go.kr/data/15101046/openapi.do
ONBID_API_KEY=your-onbid-api-key-here

# ====================================
# 고급 설정 (선택)
# ====================================
# 수집 간격 (시간 단위)
# COLLECTION_INTERVAL=24

# Rate Limit 설정
# REQUESTS_PER_MINUTE=60

# 타임아웃 (초)
# REQUEST_TIMEOUT=30

# 재시도 횟수
# MAX_RETRIES=3
